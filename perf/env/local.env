BASE_URL=http://host.docker.internal:8080
POST_CREATE_STEP=1
POST_CATEGORY_ID=1
POST_IMAGE_200KB_PATH=./assets/image-200kb.jpg

# Search limit probe (optional)
SEARCH_LIMIT_VUS=10,20,30,40,50
SEARCH_LIMIT_RAMP_DURATION=1m
SEARCH_LIMIT_HOLD_DURATION=3m
SEARCH_LIMIT_COOLDOWN_DURATION=2m

# Chat scenarios (chat/smoke-test.js, chat/load-test.js, chat/stress-test.js)
CHAT_ITEM_ID=1
CHAT_TX_TYPE=POST
CHAT_THINK_TIME=1
CHAT_MAX_USERS=100

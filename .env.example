# =========================
# Database (MySQL / OCI)
# =========================
# dev 기본값(localhost)을 덮어쓰기 하려면 아래 값 입력
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# OCI 보안 연결 옵션 (환경에 맞게 조정)
DB_USE_SSL=true
DB_REQUIRE_SSL=true
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=false

# =========================
# File Storage
# =========================
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_PATH_PREFIX=dev

# OCI Object Storage (provider=oci 일 때 필수)
OCI_REGION=ap-chuncheon-1
OCI_OBJECT_STORAGE_NAMESPACE=
OCI_OBJECT_STORAGE_BUCKET=
OCI_OBJECT_STORAGE_PAR_EXPIRE_MINUTES=30

# =========================
# OAuth (예시)
# =========================
SPRING__SECURITY__OAUTH2__CLIENT__REGISTRATION__KAKAO__CLIENT_ID=
